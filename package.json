		"pretty-quick": "^4.2.2",
		"storybook": "10.4.2",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"svelte-loader": "^3.2.4",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "8.0.16",
